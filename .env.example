# ==============================================================================
# Salary Hijacking Platform · 급여납치
# Root .env.example
#
# 이 파일은 실제 secret을 포함하지 않는 예시 환경변수 계약 파일이다.
# 실제 값은 .env, GitHub Environments, Cloudflare Secrets, Neon, EAS, 운영 secret
# storage에서 관리한다.
#
# 금지:
# - 실제 급여/지출/저축/예산/납치금액 데이터 입력 금지
# - 실제 사용자 개인정보 입력 금지
# - 실제 access token, refresh token, private key, API token 입력 금지
# - production DB URL을 local/staging/UAT에 재사용 금지
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Runtime / App Identity
# ------------------------------------------------------------------------------

NODE_ENV=development
APP_ENV=local
CI=false
TZ=Asia/Seoul

APP_PUBLIC_NAME=급여납치
APP_PUBLIC_LEGAL_NAME=Salary Hijacking
APP_PUBLIC_LOCALE=ko-KR
APP_PUBLIC_TIMEZONE=Asia/Seoul
APP_PUBLIC_CURRENCY=KRW
APP_PUBLIC_SUPPORT_EMAIL=support@example.invalid
APP_PUBLIC_SECURITY_EMAIL=security@example.invalid

# Allowed values:
# - local
# - test
# - staging
# - uat
# - production
APP_RELEASE_CHANNEL=local
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# ------------------------------------------------------------------------------
# 2. Public URLs
# ------------------------------------------------------------------------------

APP_PUBLIC_WEB_URL=http://localhost:3000
APP_PUBLIC_ADMIN_URL=http://localhost:3001
APP_PUBLIC_API_BASE_URL=http://localhost:8787
APP_PUBLIC_CDN_BASE_URL=http://localhost:8787/assets

NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=급여납치
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_ADMIN_BASE_URL=http://localhost:3001
NEXT_PUBLIC_CDN_BASE_URL=http://localhost:8787/assets

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_APP_NAME=급여납치
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
EXPO_PUBLIC_CDN_BASE_URL=http://localhost:8787/assets
EXPO_PUBLIC_PROJECT_ID=replace-with-expo-project-id
EXPO_PUBLIC_SCHEME=salaryhijacking

# ------------------------------------------------------------------------------
# 3. Database / Neon PostgreSQL
# ------------------------------------------------------------------------------

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require
SHADOW_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/SHADOW_DATABASE?sslmode=require
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/TEST_DATABASE?sslmode=require
STAGING_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/STAGING_DATABASE?sslmode=require
UAT_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/UAT_DATABASE?sslmode=require

DATABASE_SSL_MODE=require
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_MIGRATION_LOCK_TIMEOUT_MS=15000
DATABASE_APP_NAME=salary-hijacking-local

NEON_API_KEY=replace-with-neon-api-key
NEON_PROJECT_ID=replace-with-neon-project-id
NEON_BRANCH_ID=replace-with-neon-branch-id
NEON_REGION=ap-southeast-1

# ------------------------------------------------------------------------------
# 4. Server Authority / Calculation Policy
# ------------------------------------------------------------------------------

CALCULATION_TIMEZONE=Asia/Seoul
CALCULATION_CURRENCY=KRW
CALCULATION_MONEY_SCALE=0
CALCULATION_ALLOW_NEGATIVE_AMOUNT=false
CALCULATION_ALLOW_DECIMAL_AMOUNT=false
CALCULATION_HIJACK_DISPLAY_FLOOR_ZERO=true
CALCULATION_REQUIRE_SERVER_AUTHORITY=true
CALCULATION_REQUIRE_IDEMPOTENCY=true
CALCULATION_SNAPSHOT_ENABLED=true

PAYROLL_CLOSE_JOB_ENABLED=true
PAYROLL_PAYDAY_REMINDER_ENABLED=true
PAYROLL_FIXED_EXPENSE_REMINDER_ENABLED=true
PAYROLL_MONTHLY_HIJACK_CLOSE_ENABLED=true

# ------------------------------------------------------------------------------
# 5. Auth / Session / JWT
# ------------------------------------------------------------------------------

AUTH_ISSUER=salary-hijacking
AUTH_AUDIENCE=salary-hijacking-platform
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=900
AUTH_EMAIL_VERIFY_TTL_SECONDS=1800
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_REQUIRE_DEVICE_BINDING=false

JWT_ACCESS_SECRET=replace-with-at-least-64-character-random-secret
JWT_REFRESH_SECRET=replace-with-at-least-64-character-random-secret
JWT_ADMIN_SECRET=replace-with-at-least-64-character-random-secret
JWT_ALGORITHM=HS256

SESSION_COOKIE_NAME=salary_hijacking_session
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

PASSWORD_HASH_ALGORITHM=argon2id
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=3
PASSWORD_HASH_PARALLELISM=1

# ------------------------------------------------------------------------------
# 6. Social Login / OAuth
# ------------------------------------------------------------------------------

NAVER_CLIENT_ID=replace-with-naver-client-id
NAVER_CLIENT_SECRET=replace-with-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8787/auth/naver/callback

KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8787/auth/kakao/callback

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

APPLE_CLIENT_ID=replace-with-apple-client-id
APPLE_TEAM_ID=replace-with-apple-team-id
APPLE_KEY_ID=replace-with-apple-key-id
APPLE_PRIVATE_KEY=replace-with-apple-private-key-escaped-newlines
APPLE_REDIRECT_URI=http://localhost:8787/auth/apple/callback

# ------------------------------------------------------------------------------
# 7. Admin / RBAC / Audit
# ------------------------------------------------------------------------------

ADMIN_CONSOLE_ENABLED=true
ADMIN_BOOTSTRAP_EMAIL=admin@example.invalid
ADMIN_BOOTSTRAP_ROLE=OWNER
ADMIN_REQUIRE_MFA=false
ADMIN_AUDIT_LOG_ENABLED=true
ADMIN_AUDIT_MASK_BEFORE_AFTER=true
ADMIN_AUDIT_RETENTION_DAYS=1095
ADMIN_SESSION_TTL_SECONDS=3600

RBAC_ENFORCEMENT_ENABLED=true
RBAC_DEFAULT_ROLE=USER
RBAC_ADMIN_ROLES=OWNER,ADMIN,OPERATOR,MODERATOR,VIEWER

# ------------------------------------------------------------------------------
# 8. API / CORS / Rate Limit
# ------------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8787
API_BASE_PATH=/api
API_REQUEST_ID_HEADER=x-request-id
API_TRACE_ID_HEADER=x-trace-id
API_MAX_BODY_BYTES=1048576

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,exp://127.0.0.1:8081
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=authorization,content-type,x-request-id,x-idempotency-key
CORS_ALLOW_CREDENTIALS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_ADMIN_MAX_REQUESTS=300
RATE_LIMIT_COMMUNITY_WRITE_MAX_REQUESTS=30
RATE_LIMIT_EXPENSE_WRITE_MAX_REQUESTS=60

IDEMPOTENCY_HEADER=x-idempotency-key
IDEMPOTENCY_TTL_SECONDS=86400

# ------------------------------------------------------------------------------
# 9. Security / Privacy / Masking
# ------------------------------------------------------------------------------

SECURITY_SCAN_ENABLED=true
PRIVACY_CHECK_ENABLED=true
LOG_MASKING_ENABLED=true
LOG_MASK_SALARY_AMOUNT=true
LOG_MASK_EXPENSE_AMOUNT=true
LOG_MASK_SAVING_AMOUNT=true
LOG_MASK_HIJACK_AMOUNT=true
LOG_MASK_PHONE=true
LOG_MASK_EMAIL=true
LOG_MASK_IP=true
LOG_MASK_USER_AGENT=true
LOG_MASK_TOKEN=true

PII_EXPORT_ALLOWED=false
RAW_FINANCIAL_LOGGING_ALLOWED=false
RAW_AD_FINANCIAL_JOIN_ALLOWED=false
SECURITY_REPORT_PRIVATE_ONLY=true

ENCRYPTION_KEY_ID=replace-with-kms-key-id
ENCRYPTION_PRIMARY_KEY=replace-with-32-byte-base64-key
HASH_PEPPER=replace-with-at-least-32-character-random-pepper

# ------------------------------------------------------------------------------
# 10. Notifications / FCM / Push
# ------------------------------------------------------------------------------

FEATURE_NOTIFICATIONS_ENABLED=true

FCM_PROJECT_ID=replace-with-fcm-project-id
FCM_CLIENT_EMAIL=replace-with-fcm-service-account-email
FCM_PRIVATE_KEY=replace-with-fcm-private-key-escaped-newlines
FCM_PRIVATE_KEY_BASE64=replace-with-fcm-private-key-base64
FCM_TOKEN_CLEANUP_ENABLED=true
FCM_SEND_TIMEOUT_MS=10000
FCM_RETRY_MAX_ATTEMPTS=5
FCM_RETRY_BASE_DELAY_MS=1000

PUSH_PAYDAY_REMINDER_ENABLED=true
PUSH_FIXED_EXPENSE_REMINDER_ENABLED=true
PUSH_DAILY_BUDGET_REMINDER_ENABLED=true
PUSH_LEVEL_UP_REMINDER_ENABLED=true
PUSH_COMMUNITY_NOTICE_ENABLED=true

# ------------------------------------------------------------------------------
# 11. Scheduler / Jobs / Queues
# ------------------------------------------------------------------------------

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_DRY_RUN=false

JOB_PAYDAY_REMINDER_CRON=0 9 * * *
JOB_FIXED_EXPENSE_REMINDER_CRON=0 9 * * *
JOB_MONTHLY_HIJACK_CLOSE_CRON=0 1 1 * *
JOB_DATA_RETENTION_CLEANUP_CRON=0 3 * * *
JOB_PUSH_TOKEN_CLEANUP_CRON=30 3 * * *

QUEUE_NOTIFICATIONS_NAME=salary-hijacking-notifications-local
QUEUE_RETRY_NAME=salary-hijacking-retry-local
QUEUE_DEAD_LETTER_NAME=salary-hijacking-dlq-local

# ------------------------------------------------------------------------------
# 12. Cloudflare Workers / R2 / Queues
# ------------------------------------------------------------------------------

CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id

CF_WORKER_API_NAME=salary-hijacking-api-local
CF_WORKER_SCHEDULER_NAME=salary-hijacking-scheduler-local
CF_WORKER_NOTIFICATIONS_NAME=salary-hijacking-notifications-local
CF_ADMIN_WORKER_NAME=salary-hijacking-admin-local
CF_ADMIN_WORKER_ENV=local

R2_BUCKET_UPLOADS=salary-hijacking-uploads-local
R2_BUCKET_PUBLIC_ASSETS=salary-hijacking-assets-local
R2_PUBLIC_BASE_URL=http://localhost:8787/assets
R2_MAX_UPLOAD_BYTES=10485760
R2_SIGNED_URL_TTL_SECONDS=300

# ------------------------------------------------------------------------------
# 13. Uploads / Attachments
# ------------------------------------------------------------------------------

UPLOADS_ENABLED=true
UPLOADS_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOADS_MAX_FILE_BYTES=10485760
UPLOADS_REQUIRE_VIRUS_SCAN=false
UPLOADS_PUBLIC_READ=false
UPLOADS_RETENTION_DAYS=365

COMMUNITY_ATTACHMENT_ENABLED=true
COMMUNITY_ATTACHMENT_MAX_COUNT=4

# ------------------------------------------------------------------------------
# 14. Community / Moderation
# ------------------------------------------------------------------------------

FEATURE_COMMUNITY_ENABLED=true

COMMUNITY_WRITE_ENABLED=true
COMMUNITY_ANONYMOUS_DISPLAY_ENABLED=true
COMMUNITY_INTERNAL_OWNER_TRACE_ENABLED=true
COMMUNITY_REPORT_ENABLED=true
COMMUNITY_REACTION_ENABLED=true
COMMUNITY_COMMENT_ENABLED=true

MODERATION_QUEUE_ENABLED=true
MODERATION_AUTO_HIDE_REPORT_THRESHOLD=5
MODERATION_ADMIN_REVIEW_REQUIRED=true
MODERATION_PROHIBITED_CONTENT_CHECK_ENABLED=true

# ------------------------------------------------------------------------------
# 15. Level Up / Self Development
# ------------------------------------------------------------------------------

FEATURE_LEVEL_UP_ENABLED=true

LEVEL_UP_READING_ENABLED=true
LEVEL_UP_NEWS_ENABLED=true
LEVEL_UP_ENGLISH_ENABLED=true
LEVEL_UP_HEALTH_ENABLED=true
LEVEL_UP_DAILY_COMPLETION_LIMIT=20
LEVEL_UP_REWARD_ENABLED=false

# ------------------------------------------------------------------------------
# 16. Ads / Partnerships
# ------------------------------------------------------------------------------

FEATURE_ADS_ENABLED=false
FEATURE_PARTNERSHIP_ENABLED=false

ADS_DATA_SEPARATION_REQUIRED=true
ADS_RAW_FINANCIAL_DATA_ALLOWED=false
ADS_PERSONALIZED_TARGETING_ENABLED=false
ADS_CONSENT_REQUIRED=true
ADS_EVENT_RETENTION_DAYS=365
ADS_CLICK_DEDUP_WINDOW_SECONDS=86400

ADSENSE_CLIENT_ID=replace-with-adsense-client-id
ADSENSE_SLOT_HOME=replace-with-slot-id
ADSENSE_SLOT_COMMUNITY=replace-with-slot-id
ADSENSE_SLOT_PROFILE=replace-with-slot-id

PARTNER_WEBHOOK_SECRET=replace-with-partner-webhook-secret
PARTNER_API_TIMEOUT_MS=5000
PARTNER_CAMPAIGN_APPROVAL_REQUIRED=true

# ------------------------------------------------------------------------------
# 17. Observability / Logging / Metrics
# ------------------------------------------------------------------------------

LOG_LEVEL=debug
LOG_FORMAT=json
LOG_INCLUDE_REQUEST_ID=true
LOG_INCLUDE_TRACE_ID=true
LOG_INCLUDE_USER_ID=false
LOG_INCLUDE_ADMIN_ID=false
LOG_RETENTION_DAYS=90

METRICS_ENABLED=true
METRICS_NAMESPACE=salary_hijacking
METRICS_FLUSH_INTERVAL_SECONDS=30

SENTRY_DSN=replace-with-sentry-dsn
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SENTRY_ORG=replace-with-sentry-org
SENTRY_PROJECT=salary-hijacking
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

SLACK_WEBHOOK_URL=replace-with-slack-webhook-url
SLACK_SECURITY_WEBHOOK_URL=replace-with-slack-security-webhook-url
SLACK_INCIDENT_WEBHOOK_URL=replace-with-slack-incident-webhook-url

# ------------------------------------------------------------------------------
# 18. Retention / Deletion / Backup
# ------------------------------------------------------------------------------

RETENTION_POLICY_ENABLED=true
RETENTION_TIMEZONE=Asia/Seoul

RETENTION_DELETED_USER_GRACE_DAYS=30
RETENTION_FINANCIAL_DATA_DAYS=1825
RETENTION_CALCULATION_SNAPSHOT_DAYS=1825
RETENTION_NOTIFICATION_DAYS=365
RETENTION_COMMUNITY_CONTENT_DAYS=1095
RETENTION_AD_EVENT_DAYS=365
RETENTION_ADMIN_AUDIT_DAYS=1095
RETENTION_LOG_DAYS=90

BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=35
BACKUP_RESTORE_REHEARSAL_ENABLED=true
BACKUP_RESTORE_REHEARSAL_ENV=staging

# ------------------------------------------------------------------------------
# 19. QA / E2E / Test
# ------------------------------------------------------------------------------

PLAYWRIGHT_BASE_URL=http://localhost:3001
PLAYWRIGHT_API_BASE_URL=http://localhost:8787
PLAYWRIGHT_TRACE=retain-on-failure
PLAYWRIGHT_VIDEO=retain-on-failure

E2E_TEST_USER_EMAIL=e2e-user@example.invalid
E2E_TEST_USER_PASSWORD=replace-with-e2e-password
E2E_TEST_ADMIN_EMAIL=e2e-admin@example.invalid
E2E_TEST_ADMIN_PASSWORD=replace-with-e2e-admin-password

QA_SEED_PROFILE=local
QA_USE_REAL_USER_DATA=false
QA_ALLOW_NETWORK_TO_PRODUCTION=false
QA_SCREENSHOT_MASKING_ENABLED=true

# ------------------------------------------------------------------------------
# 20. Mobile Build / Expo / EAS
# ------------------------------------------------------------------------------

EXPO_TOKEN=replace-with-expo-token
EAS_PROJECT_ID=replace-with-eas-project-id
EAS_BUILD_PROFILE=development
EAS_SUBMIT_PROFILE=internal
EXPO_NO_TELEMETRY=1

ANDROID_PACKAGE=com.salaryhijacking.mobile
IOS_BUNDLE_IDENTIFIER=com.salaryhijacking.mobile

# ------------------------------------------------------------------------------
# 21. Release / GitHub
# ------------------------------------------------------------------------------

GITHUB_TOKEN=replace-with-github-token
GITHUB_REPOSITORY=jinbizman-boop/salary-hijacking
GITHUB_RELEASE_DRAFT=true
GITHUB_RELEASE_PRERELEASE=true

RELEASE_ENV=local
RELEASE_REQUIRE_CHANGELOG=true
RELEASE_REQUIRE_SECURITY_SCAN=true
RELEASE_REQUIRE_PRIVACY_CHECK=true
RELEASE_REQUIRE_DB_BACKUP=true
RELEASE_REQUIRE_ROLLBACK_PLAN=true

# ------------------------------------------------------------------------------
# 22. Feature Flags
# ------------------------------------------------------------------------------

FEATURE_ADMIN_CONSOLE_ENABLED=true
FEATURE_AUTH_SOCIAL_LOGIN_ENABLED=true
FEATURE_PAYROLL_ENABLED=true
FEATURE_DAILY_BUDGET_ENABLED=true
FEATURE_FIXED_EXPENSE_ENABLED=true
FEATURE_FIXED_SAVING_ENABLED=true
FEATURE_VARIABLE_EXPENSE_ENABLED=true
FEATURE_MY_PAGE_ENABLED=true
FEATURE_UPLOADS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_OBSERVABILITY_ENABLED=true
FEATURE_BACKUP_RESTORE_ENABLED=true
