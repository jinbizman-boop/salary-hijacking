{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Salary Hijacking Shared Types",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "allowArbitraryExtensions": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@salary-hijacking/types": ["./src/index.ts"],
      "@salary-hijacking/types/user": ["./src/domain/user.types.ts"],
      "@salary-hijacking/types/payroll": ["./src/domain/payroll.types.ts"],
      "@salary-hijacking/types/expense": ["./src/domain/expense.types.ts"],
      "@salary-hijacking/types/growth": ["./src/domain/growth.types.ts"],
      "@salary-hijacking/types/notification": [
        "./src/domain/notification.types.ts"
      ],
      "@salary-hijacking/types/community": ["./src/domain/community.types.ts"],
      "@salary-hijacking/types/domain/user": ["./src/domain/user.types.ts"],
      "@salary-hijacking/types/domain/payroll": [
        "./src/domain/payroll.types.ts"
      ],
      "@salary-hijacking/types/domain/expense": [
        "./src/domain/expense.types.ts"
      ],
      "@salary-hijacking/types/domain/growth": ["./src/domain/growth.types.ts"],
      "@salary-hijacking/types/domain/notification": [
        "./src/domain/notification.types.ts"
      ],
      "@salary-hijacking/types/domain/community": [
        "./src/domain/community.types.ts"
      ],
      "@salary-hijacking/types/domain/user.types": [
        "./src/domain/user.types.ts"
      ],
      "@salary-hijacking/types/domain/payroll.types": [
        "./src/domain/payroll.types.ts"
      ],
      "@salary-hijacking/types/domain/expense.types": [
        "./src/domain/expense.types.ts"
      ],
      "@salary-hijacking/types/domain/growth.types": [
        "./src/domain/growth.types.ts"
      ],
      "@salary-hijacking/types/domain/notification.types": [
        "./src/domain/notification.types.ts"
      ],
      "@salary-hijacking/types/domain/community.types": [
        "./src/domain/community.types.ts"
      ]
    },
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "build",
    "coverage",
    "test-results",
    "node_modules",
    ".turbo",
    ".cache",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.fixture.ts",
    "**/__tests__/**",
    "**/__fixtures__/**"
  ],
  "ts-node": {
    "esm": true,
    "transpileOnly": false,
    "compilerOptions": {
      "module": "ESNext",
      "moduleResolution": "Bundler"
    }
  },
  "salaryHijacking": {
    "packageRole": "shared-types-tsconfig",
    "contractVersion": "2.0.0",
    "packageScope": "packages/types",
    "strictModeRequired": true,
    "standaloneNoExtends": true,
    "baseUrlDeprecatedOptionRemoved": true,
    "typescript7Ready": true,
    "emitTarget": "dist",
    "entrypoint": "src/index.ts",
    "domainFiles": [
      "src/domain/user.types.ts",
      "src/domain/payroll.types.ts",
      "src/domain/expense.types.ts",
      "src/domain/growth.types.ts",
      "src/domain/notification.types.ts",
      "src/domain/community.types.ts"
    ],
    "serverAuthorityPolicy": {
      "moduleResolution": "Bundler",
      "moduleSystem": "ESNext",
      "target": "ES2022",
      "declarationRequired": true,
      "clientFinalCalculationAllowed": false,
      "moneyScale": 0,
      "currency": "KRW",
      "sensitiveRawDataInTypesPackageAllowed": false
    },
    "qualityGates": [
      "strict",
      "noUncheckedIndexedAccess",
      "exactOptionalPropertyTypes",
      "isolatedModules",
      "verbatimModuleSyntax",
      "declaration",
      "declarationMap",
      "composite",
      "incremental",
      "noEmitOnError",
      "baseUrlRemoved"
    ],
    "finalStatus": "file_unit_100_percent_document_theoretical_complete"
  }
}
