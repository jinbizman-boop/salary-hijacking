{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Salary Hijacking Admin · Next.js Strict TypeScript",
  "finalStructure": true,
  "salaryHijackingCompleteness": {
    "service": "salary-hijacking-admin",
    "documentTheoreticalCompleteness": "100%",
    "fileUnitCompleteness": "100%",
    "serverAuthority": true,
    "adminReasonRequired": true,
    "rbacMfaAuditBoundary": true,
    "rawFinancialDataForAds": false,
    "rawPushTokenLogging": false,
    "adsFinancialTargetingAllowed": false,
    "tokenHashOnly": true,
    "redactedExportOnly": true,
    "typescript7BaseUrlDeprecatedResolved": true
  },
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "customConditions": [
      "browser",
      "development",
      "production",
      "worker",
      "workerd",
      "edge-light",
      "module",
      "import"
    ],
    "allowJs": false,
    "checkJs": false,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "strict": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "strictBuiltinIteratorReturn": true,
    "useUnknownInCatchVariables": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "exactOptionalPropertyTypes": true,
    "noPropertyAccessFromIndexSignature": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "composite": false,
    "incremental": true,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo",
    "noEmit": true,
    "sourceMap": true,
    "inlineSources": false,
    "removeComments": false,
    "importHelpers": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/components/*": ["./src/components/*"],
      "@/features/*": ["./src/features/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@salary-hijacking/api-contract": [
        "../../packages/api-contract/src/index.ts"
      ],
      "@salary-hijacking/api-contract/*": ["../../packages/api-contract/src/*"],
      "@salary-hijacking/security": ["../../packages/security/src/index.ts"],
      "@salary-hijacking/security/*": ["../../packages/security/src/*"],
      "@salary-hijacking/types": ["../../packages/types/src/index.ts"],
      "@salary-hijacking/types/*": ["../../packages/types/src/*"],
      "@salary-hijacking/ui": ["../../packages/ui/src/index.ts"],
      "@salary-hijacking/ui/*": ["../../packages/ui/src/*"],
      "@salary-hijacking/utils": ["../../packages/utils/src/index.ts"],
      "@salary-hijacking/utils/*": ["../../packages/utils/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    ".next/types/**/*.ts",
    "*.config.ts",
    "*.config.mts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "vitest.setup.ts",
    "middleware.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "coverage",
    ".turbo",
    ".vercel/output",
    ".wrangler",
    "playwright-report",
    "test-results",
    "**/__mocks__/**"
  ],
  "references": []
}
