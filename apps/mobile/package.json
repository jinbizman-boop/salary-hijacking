{
  "name": "@salary-hijacking/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "급여납치 모바일 앱: 급여·예산·지출·저축·알림·LV UP·커뮤니티를 서버 권위로 연결하는 Expo/React Native 클라이언트",
  "license": "UNLICENSED",
  "type": "module",
  "main": "expo-router/entry",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0 <11"
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "doctor": "npx expo-doctor@latest",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --pretty false",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "test:e2e": "node scripts/run-e2e-ci.mjs android.emu.debug",
    "test:e2e:ios": "node scripts/check-detox-env.mjs ios.sim.debug && detox test --configuration ios.sim.debug",
    "test:e2e:android": "node scripts/check-detox-env.mjs android.emu.debug && node scripts/run-detox-android.mjs android.emu.debug",
    "e2e:android:import-apk": "node scripts/import-e2e-apk.mjs",
    "build:e2e:android:preflight": "node scripts/eas-local-android-build.mjs --check --profile e2e --output build/e2e/android/salary-hijacking-e2e.apk",
    "build:e2e:android:local-debug": "node scripts/expo-local-android-debug-build.mjs --output build/e2e/android/salary-hijacking-e2e.apk",
    "build:e2e:android:local-debug:preflight": "node scripts/expo-local-android-debug-build.mjs --check --output build/e2e/android/salary-hijacking-e2e.apk",
    "export": "expo export",
    "export:web": "expo export --platform web",
    "build:dev:android": "corepack pnpm dlx eas-cli@20.4.0 build --platform android --profile development --non-interactive",
    "build:dev:ios": "corepack pnpm dlx eas-cli@20.4.0 build --platform ios --profile development --non-interactive",
    "build:preview:android": "corepack pnpm dlx eas-cli@20.4.0 build --platform android --profile preview --non-interactive",
    "build:preview:ios": "corepack pnpm dlx eas-cli@20.4.0 build --platform ios --profile preview --non-interactive",
    "build:e2e:android": "corepack pnpm dlx eas-cli@20.4.0 build --platform android --profile e2e --non-interactive",
    "build:e2e:android:local": "node scripts/eas-local-android-build.mjs --profile e2e --output build/e2e/android/salary-hijacking-e2e.apk",
    "build:e2e:ios": "corepack pnpm dlx eas-cli@20.4.0 build --platform ios --profile e2e --non-interactive",
    "build:production:android": "corepack pnpm dlx eas-cli@20.4.0 build --platform android --profile production --non-interactive",
    "build:production:android:local-aab": "node scripts/expo-local-android-production-build.mjs --output build/release/android/salary-hijacking-production.aab",
    "build:production:android:local-aab:preflight": "node scripts/expo-local-android-production-build.mjs --check --output build/release/android/salary-hijacking-production.aab",
    "build:production:ios": "corepack pnpm dlx eas-cli@20.4.0 build --platform ios --profile production --non-interactive",
    "submit:staging:android": "corepack pnpm dlx eas-cli@20.4.0 submit --platform android --profile staging --latest --non-interactive",
    "submit:production:android": "corepack pnpm dlx eas-cli@20.4.0 submit --platform android --profile production --latest --non-interactive",
    "update:preview": "corepack pnpm dlx eas-cli@20.4.0 update --channel preview --message \"preview update\" --non-interactive",
    "update:production": "corepack pnpm dlx eas-cli@20.4.0 update --channel production --message \"production update\" --non-interactive",
    "check:package": "node -e \"const fs=require('node:fs');JSON.parse(fs.readFileSync('package.json','utf8'));console.log('package.json ok')\"",
    "check:eas": "node -e \"const fs=require('node:fs');JSON.parse(fs.readFileSync('eas.json','utf8'));console.log('eas.json ok')\"",
    "privacy:check": "node -e \"const fs=require('node:fs');const text=fs.readFileSync('package.json','utf8');const bad=['DATABASE'+'_URL','JWT'+'_SECRET','PRIVATE'+'_KEY','FCM'+'_SERVER'+'_KEY','NEON'+'_DATABASE','SERVICE'+'_ACCOUNT','ACCESS'+'_KEY','SALARY'+'_RAW','ACCOUNT'+'_NUMBER','CARD'+'_NUMBER'];const leaked=bad.filter(k=>text.includes(k));if(leaked.length)throw new Error('forbidden public secret marker: '+leaked.join(','));console.log('privacy package check passed')\"",
    "qa": "corepack pnpm run check:package && corepack pnpm run check:eas && corepack pnpm run format:check && corepack pnpm run lint && corepack pnpm run typecheck:strict && corepack pnpm run test && corepack pnpm run privacy:check && corepack pnpm run doctor",
    "ci": "corepack pnpm run qa && corepack pnpm run export"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@expo/image-utils": "0.7.6",
    "@expo/schema-utils": "0.1.0",
    "@expo/server": "0.6.3",
    "@expo/vector-icons": "^14.1.0",
    "@ide/backoff": "1.0.0",
    "@radix-ui/react-compose-refs": "1.1.2",
    "@radix-ui/react-slot": "1.2.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native/assets-registry": "0.79.6",
    "@react-native/js-polyfills": "0.79.6",
    "@react-native/normalize-colors": "0.79.6",
    "@react-native/virtualized-lists": "0.79.6",
    "@react-navigation/bottom-tabs": "7.18.3",
    "@react-navigation/core": "7.21.2",
    "@react-navigation/elements": "2.9.26",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "7.17.6",
    "@react-navigation/routers": "7.6.0",
    "@tanstack/react-query": "^5.66.0",
    "abort-controller": "3.0.0",
    "anser": "1.4.10",
    "ansi-regex": "5.0.1",
    "assert": "2.1.0",
    "badgin": "1.2.3",
    "base64-js": "1.5.1",
    "buffer": "5.7.1",
    "call-bind": "1.0.9",
    "chalk": "4.1.2",
    "client-only": "0.0.1",
    "color": "4.2.3",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "color-string": "1.9.1",
    "decode-uri-component": "0.2.2",
    "escape-string-regexp": "4.0.0",
    "event-target-shim": "5.0.1",
    "expo": "~53.0.0",
    "expo-application": "~6.1.0",
    "expo-asset": "~11.1.0",
    "expo-build-properties": "~0.14.0",
    "expo-constants": "~17.1.0",
    "expo-crypto": "~14.1.0",
    "expo-device": "~7.1.0",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.0",
    "expo-font": "~13.3.0",
    "expo-haptics": "~14.1.0",
    "expo-json-utils": "0.15.0",
    "expo-keep-awake": "~14.1.0",
    "expo-linking": "~7.1.0",
    "expo-localization": "~16.1.0",
    "expo-manifests": "0.16.6",
    "expo-notifications": "~0.31.0",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.2.0",
    "expo-splash-screen": "~0.30.0",
    "expo-status-bar": "~2.2.0",
    "expo-system-ui": "~5.0.0",
    "expo-updates": "~0.28.0",
    "expo-updates-interface": "1.1.0",
    "expo-web-browser": "~14.2.0",
    "fast-deep-equal": "3.1.3",
    "filter-obj": "1.1.0",
    "flow-enums-runtime": "0.0.6",
    "ieee754": "1.2.1",
    "invariant": "2.2.4",
    "is-arrayish": "0.3.4",
    "is-nan": "1.3.2",
    "memoize-one": "6.0.0",
    "metro-runtime": "0.82.5",
    "metro-source-map": "0.82.5",
    "nanoid": "3.3.12",
    "nullthrows": "1.1.1",
    "object-is": "1.1.6",
    "object.assign": "4.1.7",
    "pretty-format": "29.7.0",
    "promise": "8.3.0",
    "punycode": "2.3.1",
    "query-string": "7.1.3",
    "react": "19.0.0",
    "react-devtools-core": "6.1.5",
    "react-dom": "19.0.0",
    "react-fast-compare": "3.2.2",
    "react-freeze": "1.0.4",
    "react-is": "19.1.0",
    "react-native": "0.79.6",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-is-edge-to-edge": "1.3.1",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.0",
    "react-native-web": "^0.20.0",
    "regenerator-runtime": "0.13.11",
    "scheduler": "0.25.0",
    "semver": "7.6.3",
    "server-only": "0.0.1",
    "sf-symbols-typescript": "2.1.0",
    "shallowequal": "1.1.0",
    "simple-swizzle": "0.2.4",
    "split-on-first": "1.1.0",
    "stacktrace-parser": "0.1.11",
    "standard-navigation": "0.0.7",
    "strict-uri-encode": "2.0.0",
    "use-latest-callback": "0.2.6",
    "use-sync-external-store": "1.5.0",
    "util": "0.12.5",
    "warn-once": "0.1.1",
    "webidl-conversions": "5.0.0",
    "whatwg-fetch": "3.6.20",
    "whatwg-url-without-unicode": "8.0.0-3",
    "zod": "^3.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.0.0",
    "detox": "^20.34.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "prettier": "^3.5.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/app/**/*.test.ts",
      "<rootDir>/app/**/*.test.tsx",
      "<rootDir>/src/**/*.test.ts",
      "<rootDir>/src/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "src/**/*.{ts,tsx}",
      "!**/*.d.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/coverage/",
      "/dist/"
    ],
    "transformIgnorePatterns": [
      "node_modules[\\\\/](?!\\.pnpm[\\\\/]|((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?[\\\\/].*|@expo-google-fonts[\\\\/].*|react-navigation|@react-navigation[\\\\/].*|@sentry[\\\\/]react-native|native-base|react-native-svg))",
      "node_modules[\\\\/]react-native-reanimated[\\\\/]plugin[\\\\/]"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/bottom-tabs",
        "@react-navigation/native-stack"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "detox",
          "eas-cli",
          "fast-deep-equal",
          "react-native-is-edge-to-edge",
          "sf-symbols-typescript",
          "prettier"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
